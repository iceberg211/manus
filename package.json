{
  "name": "manus",
  "version": "0.1.0",
  "description": "AI Agent framework built with LangGraph TypeScript",
  "type": "module",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "server": "tsx server/index.ts",
    "web": "cd web && npm run dev",
    "web:install": "cd web && npm install",
    "web:build": "cd web && npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/openai": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@visactor/vmind": "^2.0.10",
    "browser-use": "^0.6.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "duck-duck-scrape": "^2.2.7",
    "hono": "^4.12.14",
    "langchain": "^1.3.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1",
    "smol-toml": "^1.6.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas"
    ]
  }
}
